rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /styles/{styleId} {
      allow read, write: if true;
    }
    match /attachments/{attachmentId} {
      allow read, write: if true;
    }
    match /logs/{logId} {
      allow read, write: if true;
    }
    match /notifications/{notificationId} {
      allow read, write: if true;
    }
    match /test/{docId} {
      allow read, write: if true;
    }
  }
}
